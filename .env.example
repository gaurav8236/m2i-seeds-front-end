# Supabase (required)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API — defaults to Railway prod if not set
# For local dev: set this to http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# LogRocket — session recording (get app ID from app.logrocket.com)
# Leave blank to disable (safe for local dev)
VITE_LOGROCKET_APP_ID=yourorg/smartdukan
